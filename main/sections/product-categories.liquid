<section
  class="section section--half-bleed section--pbe-0"
  id="product-categories"
>
  <div class="section-content section-content--horizontal">
    <div class="section-head section-head--vertical">
      {% if section.settings.title != blank %}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {% endif %}
      <div class="section-actions">
        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <div class="section-action">
            <a
              href="{{ section.settings.button_link }}"
              class="button button--primary button--default button--hoverable"
            >
              <span class="button-text">{{ section.settings.button_text }}</span>
            </a>
          </div>
        {% endif %}
        <div class="slider-controls slider-controls--visible-desktop">
          <a href="" class="slider-control slider-control--prev">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </a>
          <a href="" class="slider-control slider-control--next">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </a>
        </div>
      </div>
    </div>
    {% if section.blocks.size > 0 %}
      <div class="section-body">
        <div class="product-categories-slider">
          <div class="swiper">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.link | default: '#' }}" class="product-category-card">
                    {% if block.settings.image != blank %}
                      <div class="product-category-card-media">
                        <img
                          class="product-category-card-img"
                          src="{{ block.settings.image | image_url: width: 600 }}"
                          alt="{{ block.settings.image.alt | default: block.settings.title }}"
                          width=""
                          height=""
                          loading="lazy"
                        >
                      </div>
                    {% endif %}
                    {% if block.settings.title != blank %}
                      <div class="product-category-card-info">
                        <h3 class="product-category-card-title">{{ block.settings.title }}</h3>
                      </div>
                    {% endif %}
                  </a>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="slider-controls slider-controls--visible-mobile">
          <div class="slider-control slider-control--prev">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </div>
          <div class="slider-control slider-control--next">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof Swiper !== 'undefined') {
      new Swiper('#product-categories .swiper', {
        slidesPerView: 'auto',
        spaceBetween: 16,
        navigation: {
          nextEl: '#product-categories .slider-control--next',
          prevEl: '#product-categories .slider-control--prev',
        },
      });
    } else {
      console.error('Swiper library is not loaded');
    }
  });
</script>

{% schema %}
{
  "name": "Product Categories",
  "tag": "section",
  "class": "product-categories-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "From Gatherings to Quiet Moments, Explore Possibilities for Everyday Luxury"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Product Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Serve-ware"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Seating"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Tables"
          }
        }
      ]
    }
  ]
}
{% endschema %}
