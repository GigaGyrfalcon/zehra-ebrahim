<section class="section section--pbs-0">
  <div class="container">
    <div class="section-content">
      <div class="section-head">
        <div class="page-head page-head--align-start">
          {% render 'breadcrumbs' %}
          <div class="page-head-info">
            <h2 class="page-title">{{ section.settings.heading }}</h2>
            <div class="page-head-text">
              <p>{{ section.settings.subheading }}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="section-body">
        <div class="contact">
          <div class="contact-item">
            {% form 'contact' %}
              {% if form.posted_successfully? %}
                <p style="margin-bottom: 1rem; padding: 0.75rem 1rem; background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; border-radius: 4px; font-size: 1.6rem;">
                  Thanks for contacting us. We'll get back to you as soon as possible.
                </p>
              {% endif %}
              {% if form.errors %}
                <ul style="margin-bottom: 1rem; padding: 0.75rem 1rem 0.75rem 2rem; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 4px; font-size: 1.6rem;">
                  {% for error in form.errors %}
                    <li>{{ error | capitalize }}: {{ form.errors.messages[error] }}</li>
                  {% endfor %}
                </ul>
              {% endif %}
              <div class="form-content">
                <div class="form-group">
                  <label class="form-label" for="ContactName"
                    >Full Name <span class="form-label-required">*</span></label
                  >
                  <div class="form-group-content">
                    <input
                      type="text"
                      id="ContactName"
                      name="contact[name]"
                      class="form-field"
                      placeholder="Full Name"
                      value="{{ form.name }}"
                      required
                    >
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label" for="ContactEmail"
                    >Email Address <span class="form-label-required">*</span></label
                  >
                  <div class="form-group-content">
                    <input
                      type="email"
                      id="ContactEmail"
                      name="contact[email]"
                      class="form-field"
                      placeholder="Email Address"
                      value="{{ form.email }}"
                      autocomplete="email"
                      required
                    >
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label" for="ContactSubject"
                    >Subject <span class="form-label-required">*</span></label
                  >
                  <div class="form-group-content">
                    <input
                      type="text"
                      id="ContactSubject"
                      name="contact[subject]"
                      class="form-field"
                      placeholder="Subject"
                      required
                    >
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label" for="ContactMessage"
                    >Message <span class="form-label-required">*</span></label
                  >
                  <div class="form-group-content">
                    <textarea
                      id="ContactMessage"
                      name="contact[body]"
                      class="form-field form-field--textarea"
                      placeholder="Write here..."
                      required
                    >{{ form.body }}</textarea>
                  </div>
                </div>
                <div class="form-group">
                  <div class="form-actions">
                    <button type="submit" class="button button--primary button--hoverable button--default">
                      <span class="button-text">Submit</span>
                    </button>
                  </div>
                </div>
              </div>
            {% endform %}
          </div>
          <div class="contact-item">
            <div class="contact-info">
              <div class="contact-info-item">
                <h6 class="contact-info-item-title">{{ section.settings.enquiries_title }}</h6>
                <div class="contact-info-item-content">
                  {% if section.settings.email != blank %}
                    <a href="mailto:{{ section.settings.email }}" class="contact-info-item-text">
                      {{- section.settings.email -}}
                    </a>
                  {% endif %}
                  {% if section.settings.phone_1 != blank %}
                    <a href="tel:{{ section.settings.phone_1 | remove: ' ' }}" class="contact-info-item-text">
                      {{- section.settings.phone_1 -}}
                    </a>
                  {% endif %}
                  {% if section.settings.phone_2 != blank %}
                    <a href="tel:{{ section.settings.phone_2 | remove: ' ' }}" class="contact-info-item-text">
                      {{- section.settings.phone_2 -}}
                    </a>
                  {% endif %}
                  {% if section.settings.phone_disclaimer != blank %}
                    <span class="contact-info-item-disclaimer">{{ section.settings.phone_disclaimer }}</span>
                  {% endif %}
                </div>
              </div>
              <div class="contact-info-item">
                <h6 class="contact-info-item-title">{{ section.settings.timings_title }}</h6>
                <div class="contact-info-item-content">
                  <div class="contact-info-item-text">
                    {{ section.settings.timings_text }}
                  </div>
                </div>
              </div>
              <div class="contact-info-item">
                <h6 class="contact-info-item-title">{{ section.settings.address_title }}</h6>
                <div class="contact-info-item-content">
                  <p class="contact-info-item-text">{{ section.settings.address_text }}</p>
                </div>
              </div>
              <div class="contact-info-item">
                <h6 class="contact-info-item-title">{{ section.settings.social_title }}</h6>
                <div class="contact-info-item-content">
                  {% if section.settings.facebook_url != blank %}
                    <a href="{{ section.settings.facebook_url }}" class="contact-info-item-text">Facebook</a>
                  {% endif %}
                  {% if section.settings.instagram_url != blank %}
                    <a href="{{ section.settings.instagram_url }}" class="contact-info-item-text">Instagram</a>
                  {% endif %}
                </div>
              </div>
              <div class="contact-info-item contact-info-item--fw">
                <div class="contact-info-item-media">
                  {% if section.settings.contact_image != blank %}
                    <img
                      src="{{ section.settings.contact_image | image_url: width: 800 }}"
                      alt="{{ section.settings.contact_image.alt | escape }}"
                      class="contact-info-item-media-img"
                      width="{{ section.settings.contact_image.width }}"
                      height="{{ section.settings.contact_image.height }}"
                      loading="lazy"
                    >
                  {% else %}
                    <img
                      src="{{ 'contact-1.jpg' | asset_url }}"
                      alt=""
                      class="contact-info-item-media-img"
                      width=""
                      height=""
                    >
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
          <div class="contact-item contact-item--fw">
            <div class="contact-map">
              <div id="map"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initMap() {
    const location = { lat: {{ section.settings.map_lat }}, lng: {{ section.settings.map_lng }} };
    const map = new google.maps.Map(document.getElementById('map'), {
      zoom: 15,
      center: location,
    });
    const marker = new google.maps.Marker({
      position: location,
      map: map,
      title: {{ section.settings.map_marker_title | json }},
    });
  }
</script>
{% if section.settings.map_api_key != blank %}
  <script
    src="https://maps.googleapis.com/maps/api/js?key={{ section.settings.map_api_key }}&callback=initMap"
    async
    defer
  ></script>
{% endif %}

