<section class="ze-reviews-accordion page-width">
  <details
    class="ze-acc"
    {% if section.settings.open_by_default %}
      open
    {% endif %}
  >
    <summary class="ze-acc__summary">
      <span class="ze-acc__title">{{ section.settings.heading }}</span>
      <span class="ze-acc__chevron" aria-hidden="true">▾</span>
    </summary>

    <div class="ze-acc__content">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when '@app' %}
            {% render block %}
        {% endcase %}
      {% endfor %}
    </div>
  </details>
</section>

<style>
  .ze-reviews-accordion {
    margin-top: 24px;
    margin-bottom: 24px;
  }
  .ze-acc {
    border: 0;
    background: transparent;
  }
  .ze-acc__summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    cursor: pointer;
    padding: 10px 0;
  }
  .ze-acc__summary::-webkit-details-marker {
    display: none;
  }
  .ze-acc__title {
    font-size: 32px;
    font-weight: 600;
  }
  .ze-acc__chevron {
    font-size: 20px;
    transform: translateY(2px);
    transition: transform 0.2s ease;
  }
  details[open] .ze-acc__chevron {
    transform: rotate(180deg) translateY(-2px);
  }

  .ze-acc__content {
    padding: 10px 0 0;
  }
</style>

{% schema %}
{
  "name": "Quoli Reviews Accordion",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Reviews" },
    { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": true }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "Quoli Reviews Accordion" }]
}
{% endschema %}
