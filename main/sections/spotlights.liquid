<section class="section section--solid-bg section--half-bleed" id="spotlights">
  <div class="section-content">
    <div class="section-head section-head--fw">
      {% if section.settings.title != blank %}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {% endif %}
      <div class="section-actions">
        <div class="slider-controls slider-controls--visible-desktop">
          <a href="" class="slider-control slider-control--prev">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </a>
          <a href="" class="slider-control slider-control--next">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </a>
        </div>
      </div>
    </div>
    {% if section.blocks.size > 0 %}
      <div class="section-body">
        <div class="spotlights-slider">
          <div class="swiper">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.link | default: '#' }}" class="spotlight-card">
                    {% if block.settings.image != blank %}
                      <div class="spotlight-card-media">
                        <img
                          class="spotlight-card-img"
                          src="{{ block.settings.image | image_url: width: 800 }}"
                          alt="{{ block.settings.image.alt | default: block.settings.title }}"
                          height=""
                          width=""
                          loading="lazy"
                        >
                      </div>
                    {% endif %}
                    {% if block.settings.title != blank %}
                      <div class="spotlight-card-info">
                        <h3 class="spotlight-card-title">{{ block.settings.title }}</h3>
                      </div>
                    {% endif %}
                  </a>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="slider-controls slider-controls--visible-mobile">
          <div class="slider-control slider-control--prev">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </div>
          <div class="slider-control slider-control--next">
            <svg class="slider-control-icon">
              <use href="{{ 'icons.svg' | asset_url }}#symbol-arrow"></use>
            </svg>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof Swiper !== 'undefined') {
      new Swiper('#spotlights .swiper', {
        slidesPerView: 'auto',
        spaceBetween: 16,
        navigation: {
          nextEl: '#spotlights .slider-control--next',
          prevEl: '#spotlights .slider-control--prev',
        },
      });
    } else {
      console.error('Swiper library is not loaded');
    }
  });
</script>

{% schema %}
{
  "name": "Spotlights Slider",
  "tag": "section",
  "class": "spotlights-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Spotlight"
    }
  ],
  "blocks": [
    {
      "type": "spotlight",
      "name": "Spotlight Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Spotlight Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Spotlight Title",
          "default": "Project Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Spotlight Link",
          "info": "Link to spotlight detail page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Spotlights Slider",
      "blocks": [
        {
          "type": "spotlight"
        },
        {
          "type": "spotlight"
        },
        {
          "type": "spotlight"
        }
      ]
    }
  ]
}
{% endschema %}
